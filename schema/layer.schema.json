{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/duolahypercho/claude-micro-layer/blob/main/schema/layer.schema.json",
  "title": "Claude Micro Layer Pack",
  "type": "object",
  "required": ["formatVersion", "device", "name", "layer"],
  "properties": {
    "formatVersion": {
      "const": 1
    },
    "device": {
      "const": "codex_micro"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "actionGroupColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "linkedApp": {
      "type": "object",
      "description": "App that Input auto-switches to this layer for; matched by process bundle id (preferred) or app path on install.",
      "anyOf": [
        { "required": ["process"] },
        { "required": ["path"] }
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "process": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "multiActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/multiAction"
      }
    },
    "layer": {
      "type": "object",
      "required": ["name", "layout"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "integer",
          "minimum": 0,
          "maximum": 16777215
        },
        "layout": {
          "type": "object",
          "required": ["keymap"],
          "properties": {
            "keymap": {
              "type": "array",
              "prefixItems": [
                {
                  "$ref": "#/$defs/twoKeys"
                },
                {
                  "$ref": "#/$defs/fourKeys"
                },
                {
                  "$ref": "#/$defs/fourKeys"
                },
                {
                  "$ref": "#/$defs/threeKeys"
                }
              ],
              "minItems": 4,
              "maxItems": 4
            },
            "encoders": {
              "type": "array",
              "prefixItems": [
                {
                  "$ref": "#/$defs/threeKeys"
                }
              ],
              "minItems": 1,
              "maxItems": 1
            },
            "joystick": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "lights": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "required": ["id", "name", "keyInputs"],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": ["string", "null"]
        },
        "icon": {
          "type": ["string", "null"]
        },
        "keyInputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["keycode", "delay", "actionType"],
            "properties": {
              "keycode": {
                "$ref": "#/$defs/keycode"
              },
              "delay": {
                "type": "integer",
                "minimum": 0
              },
              "actionType": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "multiAction": {
      "type": "object",
      "required": [
        "id",
        "name",
        "tap",
        "onHold",
        "doubleTap",
        "tapHold",
        "tappingTerms"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": ["string", "null"]
        },
        "icon": {
          "type": ["string", "null"]
        },
        "tap": {
          "$ref": "#/$defs/keyInput"
        },
        "onHold": {
          "$ref": "#/$defs/keyInput"
        },
        "doubleTap": {
          "$ref": "#/$defs/keyInput"
        },
        "tapHold": {
          "$ref": "#/$defs/keyInput"
        },
        "tappingTerms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 1000
        }
      },
      "additionalProperties": false
    },
    "keyInput": {
      "type": "object",
      "required": ["keycode", "delay", "actionType"],
      "properties": {
        "keycode": {
          "$ref": "#/$defs/keycode"
        },
        "delay": {
          "type": "integer",
          "minimum": 0
        },
        "actionType": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      },
      "additionalProperties": false
    },
    "keycode": {
      "type": "string",
      "minLength": 1
    },
    "twoKeys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keycode"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "threeKeys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keycode"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "fourKeys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keycode"
      },
      "minItems": 4,
      "maxItems": 4
    }
  },
  "additionalProperties": true
}
